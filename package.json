{
  "name": "vsclaude",
  "version": "0.2.0",
  "private": true,
  "description": "Claude Code, in motion. For any model. A cozy IDE where you watch your AI agent work through living pixel-art animation.",
  "keywords": [
    "ide",
    "ai",
    "claude-code",
    "agent",
    "tauri",
    "monaco",
    "pixel-art",
    "developer-tools"
  ],
  "homepage": "https://github.com/AnwarDebes/vsclaude",
  "bugs": {
    "url": "https://github.com/AnwarDebes/vsclaude/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnwarDebes/vsclaude.git"
  },
  "license": "MIT",
  "author": "Anwar Debes",
  "type": "module",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @vsclaude/desktop dev",
    "tauri": "pnpm --filter @vsclaude/desktop tauri",
    "tauri:dev": "pnpm --filter @vsclaude/desktop tauri:dev",
    "tauri:build": "pnpm --filter @vsclaude/desktop tauri:build",
    "build": "pnpm run build:packages && pnpm --filter @vsclaude/desktop build",
    "build:packages": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "pnpm --filter @vsclaude/design-system run storybook",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build:packages && changeset publish",
    "clean": "pnpm -r exec rimraf dist build target .turbo *.tsbuildinfo"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
