    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@vsclaude/agent-runtime": "workspace:*",
    "@vsclaude/chat": "workspace:*",
    "@vsclaude/contracts": "workspace:*",
    "@vsclaude/core-shell": "workspace:*",
    "@vsclaude/design-system": "workspace:*",
    "@vsclaude/editor": "workspace:*",
    "@vsclaude/motion": "workspace:*",
    "@vsclaude/persistence": "workspace:*",
    "@vsclaude/swarm": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.5"
