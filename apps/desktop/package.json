    "@vsclaude/design-system": "workspace:*",
    "@vsclaude/editor": "workspace:*",
    "@vsclaude/git": "workspace:*",
    "@vsclaude/motion": "workspace:*",
    "@vsclaude/persistence": "workspace:*",
    "@vsclaude/providers": "workspace:*",
