{
  "name": "@vsclaude/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "The vsclaude desktop application: a Tauri shell wrapping the React renderer.",
  "license": "MIT",
  "author": "Anwar Debes",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
