{
  "name": "@vsclaude/plugin-sdk",
  "version": "0.1.0",
  "description": "The plugin host: manifest validation, compatibility checks, and registration lifecycle.",
  "license": "MIT",
  "author": "Anwar Debes",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vsclaude/contracts": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
